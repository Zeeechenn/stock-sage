# Copy this file to .env and fill in real values.
#
# Sections:
# 1. Basic local runtime
# 2. Optional LLM and data providers
# 3. Optional local/remote agent guardrails

# --- 1. Basic local runtime -------------------------------------------------

# Database. Leave unset to use stock-sage.db in the project root.
# DATABASE_URL=sqlite:////absolute/path/to/stock-sage.db

# Scheduler defaults to manual/off for packaged or single-user local builds.
SCHEDULER_ENABLED=false

# Scheduler times, 24-hour format.
SCHEDULE_PREMARKET=08:30
SCHEDULE_POSTMARKET=16:00
SCHEDULE_LONGTERM_DOW=sun
SCHEDULE_LONGTERM_TIME=11:00

# Logging.
LOG_LEVEL=INFO

# --- 2. Optional LLM and data providers -------------------------------------

# LLM runtime provider: anthropic, openai, or local_cli.
# Use local_cli for local agent/runtime tests without Anthropic/OpenAI project keys.
AI_PROVIDER=anthropic

# Anthropic, used only when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI or OpenAI-compatible providers, used only when AI_PROVIDER=openai.
# Examples: DeepSeek, Moonshot, Tongyi Qianwen, Azure OpenAI.
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=

# A-share daily data supplement. Optional Tushare Pro token; empty skips Tushare.
# StockSage uses Tushare daily unadjusted OHLCV only. Official docs list daily
# as 120 points and basic quota as 500 RPM / 6000 rows per request.
TUSHARE_TOKEN=

# Signal weights. The three weights must sum to 1.0.
# WEIGHT_QUANT=0.0
# WEIGHT_TECHNICAL=0.6
# WEIGHT_SENTIMENT=0.4
# NEW_FRAMEWORK_ENTRY_THRESHOLD=25.0

# Paper-trading profile: auto, test1_legacy_qlib, or new_framework.
# PAPER_TRADING_PROFILE=auto

# Risk and exit controls.
# ATR_PERIOD=14
# ATR_MULTIPLIER=2.0
# RISK_REWARD_RATIO=2.0
# TAKE_PROFIT_EXIT_ENABLED=false
# TIME_EXIT_ENABLED=false
# MAX_HOLD_DAYS=10
# TRAILING_STOP_ENABLED=true
# TRAILING_ATR_MULT=2.5

# Multi-agent and long-term analysis switches.
# Daily/batch signals keep multi-agent off by default to control token spend.
# Enable MULTI_AGENT_ENABLED only for explicit single-stock research or experiments.
# MULTI_AGENT_ENABLED=false
# RISK_MANAGER_ENABLED=true
# LAYERED_MEMORY_ENABLED=true
# LONG_TERM_TEAM_ENABLED=true
# LONG_TERM_A_TEACHER_ENABLED=true
# LONG_TERM_PIOTROSKI_ENABLED=true
# LONG_TERM_JINGQI_ENABLED=true
# LONG_TERM_QFII_FLOW_ENABLED=true

# Kronos. Optional; requires GPU/CUDA and extra model dependencies.
# KRONOS_ENABLED=false
# KRONOS_MODEL=NeoQuasar/Kronos-small
# KRONOS_PRED_LEN=5

# Tavily Search API. Optional supplement for realtime news.
# Free Researcher plan is 1000 credits/month; basic search costs 1 credit.
# TAVILY_API_KEY=your_tavily_api_key_here
# TAVILY_SUPPLEMENT_THRESHOLD=3

# Anspire Search API. Optional strict supplement for event-type stock news.
# Trial/promotional quota is platform-controlled; check the Anspire console.
# ANSPIRE_API_KEY=your_anspire_api_key_here
# ANSPIRE_NEWS_DAYS=2
# ANSPIRE_NEWS_MAX_RESULTS=5
# ANSPIRE_NEWS_MAX_ADD=2
# ANSPIRE_NEWS_MIN_SCORE=75

# Bark push notifications. Optional iOS push integration.
# BARK_KEY=your_device_key_here
# BARK_SERVER=https://api.day.app

# --- 3. Optional local/remote agent guardrails -------------------------------

# Agent bridge mode.
# Local Codex / Claude Code use should leave this as local: no extra permission
# gate, because the assistant is already running on the owner's machine.
STOCKSAGE_AGENT_MODE=local

# Remote agent hosting is opt-in. If STOCKSAGE_AGENT_MODE=remote, require a
# non-empty API key at the hosting layer. Remote mode stays read-only unless
# STOCKSAGE_AGENT_REMOTE_WRITE_ENABLED=true is explicitly set. If write is
# enabled, STOCKSAGE_AGENT_REMOTE_WRITE_ACTIONS can restrict writes by action
# name, for example watchlist.add,memory.write,review.daily.ensure.
# STOCKSAGE_AGENT_API_KEY=change_me_for_remote_only
# STOCKSAGE_AGENT_REMOTE_WRITE_ENABLED=false
# STOCKSAGE_AGENT_REMOTE_WRITE_ACTIONS=
