# 复制此文件为 .env 并填入真实值
ANTHROPIC_API_KEY=your_claude_api_key_here

# 数据库
# 推荐使用绝对路径，避免从不同目录启动时写错 DB
DATABASE_URL=sqlite:////path/to/stock-sage/stock-sage.db

# 调度时间（24小时制，北京时间）
SCHEDULE_PREMARKET=08:30
SCHEDULE_POSTMARKET=16:00

# A股数据源（可选，Tushare Pro token，不填则用免费AkShare）
TUSHARE_TOKEN=

# 日志级别
LOG_LEVEL=INFO
