# ── LLM 提供方 ────────────────────────────────────────────────────
# 支持：anthropic（默认）、openai（含兼容接口）
AI_PROVIDER=anthropic

# Anthropic（AI_PROVIDER=anthropic 时使用）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI / 兼容接口（AI_PROVIDER=openai 时使用）
# 兼容示例：DeepSeek、Moonshot、通义千问、Azure OpenAI 等
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=                         # 留空 = OpenAI 官方；改为第三方地址即可切换

# ── 数据库（默认使用项目根目录下的 SQLite）────────────────────────
# 使用绝对路径，避免从不同目录启动时写错 DB
# DATABASE_URL=sqlite:////path/to/stock-sage/stock-sage.db

# ── 调度时间（24h 格式，仅工作日）──────────────────────────────────
# SCHEDULE_PREMARKET=08:30
# SCHEDULE_POSTMARKET=16:00

# ── 信号权重（三项之和须为 1.0）────────────────────────────────────
# Phase 5 三路融合（当前默认）
# WEIGHT_QUANT=0.45
# WEIGHT_TECHNICAL=0.40
# WEIGHT_SENTIMENT=0.15

# ── Kronos（可选，需 CUDA GPU）──────────────────────────────────────
# KRONOS_ENABLED=false

# ── Bark 推送（可选，iOS App）───────────────────────────────────────
# BARK_KEY=your_device_key_here
# BARK_SERVER=https://api.day.app      # 自建服务时替换
